{
  "version": 2,
  "builds": [
    {
      "src": "dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "pragma": "no-cache"
      },
      "dest": "/dist/$1"
    }
  ],
  "buildCommand": "npm install && npm run generate && for f in dist/static/*.html; do mv -- \"$f\" \"${f%.html}.svg\"; done",
  "outputDirectory": "dist"
}