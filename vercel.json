{
  "version": 2,
  "builds": [
    {
      "src": "dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "pragma": "no-cache"
      },
      "dest": "/dist/$1"
    }
  ],
  "buildCommand": "npm install && npm run generate && mv dist/static/* dist",
  "outputDirectory": "dist"
}